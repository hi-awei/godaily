\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\nd:[[\"$\",\"title\",\"0\",{\"children\":\"Z.ai - Inspiring AGI to Benefit Humanity\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"智谱推出 AutoClaw（澳龙）——国内首款一键安装的本地 OpenClaw 客户端。内置50+Skills，集成 AutoGLM 浏览器操作能力，下载地址：https://autoglm.zhipuai.cn/autoclaw\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"z.ai, 智谱AI, 智谱清言, zhipuai, 智谱官网, GLM, GLM-5, GLM-4.7, GLM-4.6V, GLM-4.5V, AutoClaw, 澳龙, AutoGLM, CogAgent, AI平台, 免费AI助手, AI API, LLM API, 大模型API, 开发者AI工具, 多模态AI, 视觉语言模型, VLM, AI编程助手, GLM Coding Plan, 代码补全AI, AI代码生成, AI图像生成, AI视频生成, AI PPT, AI文档分析, AI OCR, 模型微调, AI搜索, 企业AI解决方案, 企业大模型, 程序员AI工具, 开源大模型, AGI, Zread.ai, AMiner\"}],[\"$\",\"link\",\"3\",{\"rel\":\"icon\",\"href\":\"/favicon.png\"}],[\"$\",\"$Lf\",\"4\",{}]]\n9:null\n5:[\"$\",\"html\",null,{\"lang\":\"favicon.ico\",\"children\":[\"$\",\"body\",null,{\"className\":\"flex min-h-screen flex-col overflow-y-scroll antialiased en-win-font\",\"children\":\"$L10\"}]}]\n"])</script><script>self.__next_f.push([1,"4:[\"$\",\"$L11\",null,{\"formats\":\"$undefined\",\"locale\":\"zh\",\"messages\":{\"about\":\"关于我们\",\"about_title\":\"关于智谱\",\"about_zhipu_desc\":\"智谱（Z.AI）成立于2019年，由清华大学技术成果转化而来。公司以“让机器像人一样思考”为愿景，始终专注通用人工智能（AGI）的研发。团队率先启动国内大模型的研究工作，研发出基于自回归填空的全国产预训练架构GLM，在鲁棒性、可控性和幻觉性方面取得出众效果，模型适配了40余款国产芯片。\u003cbr/\u003e\u003cbr/\u003e2025年，智谱（Z.AI）推出新一代旗舰模型GLM-4.5/4.6，首次实现在一个模型中原生融合推理、编码和智能体能力，模型立即在12项权威评测中综合排名取得国内第一、全球开源第一的效果。尤其是模型的Coding能力取得关键突破，在全球公认百万用户盲测的大模型竞技场Code Arena上，GLM与Anthropic、OpenAI的模型并列Coding全球第一，超越海外闭源模型谷歌Gemini和xai的Grok，第一次有中国模型实现该名次。在全球大模型超市OpenRouter（体现全球大模型真实调用量）上，GLM-4.5/4.6自上线以来调用量稳居全球前10，同时付费API收入超过所有国产模型之和。\u003cbr/\u003e\u003cbr/\u003e智谱连续三年实现收入翻倍增长，已经发展成为中国大型的独立大模型厂商。目前，GLM系列大模型应用于民生治理、工业制造、能源电力、金融、互联网、通信、消费电子、教育等行业，拥有超过270万的客户与开发者。\",\"about_zhipu_title\":\"北京智谱华章科技股份有限公司\",\"about_hero_title\":\"让机器像人一样思考\",\"about_hero_desc\":\"Teach machines to think like humans\",\"address\":\"北京市海淀区中关村东路 1 号院 9 号楼 10 层\",\"ai_slides\":\"AI Slides\",\"maasSection\":{\"description\":\"我们不止生产模型  更构建可信智能\",\"description1\":\"提供能力全球领先、灵活易用、高性价比的全模态大模型 API 服务\",\"description2\":\"数十个深度耦合业务的应用级 API，开箱即用，直击千行百业真需求\",\"description3\":\"一站式、组件化大模型开发，享受高效定制模型体验，保障企业级 AI 应用落地\",\"items1\":{\"desc1\":\"智谱面向智能体工程推出的全新旗舰基座模型，在编码和智能体能力方面实现了开源SOTA性能\",\"desc2\":\"视觉理解精度达同规模 SOTA，原生支持工具调用，能自动完成任务，支持 128K 长上下文\"},\"items2\":{\"desc1\":\"精通多国语种，精确识别语境、语体、俚语及专业术语，实现高保真情景化翻译\",\"desc2\":\"从搜索到设计，一键生成精美可用的PPT/海报, 文字图表智能完美融合\",\"title1\":\"通用翻译\",\"title2\":\"GLM PPT/海报\"},\"items3\":{\"desc1\":\"支持对语言、多模态模型的多种微调方案，低至十分钟完成微调，让模型更懂你的任务场景\",\"desc2\":\"集成多家搜索引擎，专为大模型优化，助力 AI 应用生成实时、精准、可溯源的内容\",\"title1\":\"模型微调\",\"title2\":\"AI 搜索工具\"},\"title1\":\"高效能模型服务\",\"title2\":\"精选智能体应用\",\"title3\":\"全流程开发套件\",\"viewAll\":\"查看全部\"},\"autoglm\":{\"desc\":\"自主规划并执行复杂多步骤任务的智能体模型\"},\"banner_button\":\"立刻了解\",\"banner_text\":\"GLM Coding Plan 编码套餐：低至20元包月，畅享全球顶级编码体验\",\"businessEcosystem\":{\"description\":\"帮助行业合作伙伴与各城市做出成功的大模型应用\",\"title\":\"商业生态\"},\"business_cooperation\":\"商务合作\",\"marketing\":\"市场公关\",\"investors_relations\":\"投资者关系\",\"business_license\":\"营业执照\",\"chat_placeholder\":\"今天有什么可以帮助你？\",\"chatglm_6b\":{\"desc\":\"中国第一个对话模型\"},\"contact_business_type\":\"※ 您咨询的业务类型\",\"contact_button_text\":\"合作咨询\",\"contact_code\":\"※ 请输入验证码\",\"contact_company\":\"※ 您的公司名称\",\"contact_description\":\"我们最新的前沿模型系列，在推理、编码和智能体任务方面表现出色\",\"contact_name\":\"※ 请输入您的姓名\",\"contact_phone\":\"※ 请输入您的电话\",\"contact_select_digital_human\":\"数字人\",\"contact_select_llm\":\"大模型\",\"contact_select_news_media\":\"新闻媒体\",\"contact_select_other\":\"其它\",\"contact_submit\":\"预约咨询\",\"contact_submit_error\":\"网络异常，表单提交失败，请检查网络后重试\",\"contact_submit_error_desc\":\"请稍后再试\",\"contact_submit_success\":\"提交成功\",\"contact_submit_success_desc\":\"我们会尽快与您联系\",\"contact_submitting\":\"提交中...\",\"contact_title\":\"业务咨询\",\"copyright\":\"Copyright ◎ 2025-2026 北京智谱华章科技股份有限公司\",\"ending\":{\"button\":\"免费试用\",\"description\":\"注册立享 2000万 tokens\",\"title\":\"日均付费调用量超万亿tokens  累计服务超270万开发者，日活超20万开发者\",\"title1\":\"中国大型独立大模型厂商,\",\"title2\":\"国产原创GLM大模型架构，编程能力并列全球第一\",\"title_mobile1\":\"中国大型独立大模型厂商\",\"title_mobile2\":\"国产原创GLM大模型架构\",\"title_mobile3\":\"编程能力并列全球第一\"},\"full_stack\":\"Full Stack\",\"glmSection\":{\"glm_5\":{\"title\":\"GLM-5\",\"desc\":\"在 SWE-bench Verified、Terminal Bench 2.0 等智能体编程核心榜单上，GLM-5 达到开源模型 SOTA，比肩 Claude Opus 4.5\"},\"glm_5_t\":{\"title\":\"GLM-5-Turbo\",\"desc\":\"专为龙虾场景打造的基座模型\"},\"glm_4_6V\":{\"title\":\"GLM-4.6V\",\"desc\":\"全球 100B 级效果表现出众的开源视觉推理模型，并同步开源\"},\"autoGLM\":{\"title\":\"AutoGLM\",\"desc\":\"具备自主规划、推理与执行能力的智能体模型，解决了任务规划、数据稀缺和策略优化等核心难题，具备持续自我改进能力\"},\"cogView4\":{\"title\":\"CogView4\",\"desc\":\"擅长理解和遵循中文提示词，能够在画面中生成汉字的开源文生图模型\"},\"glm_Z1_Rumination\":{\"title\":\"GLM-Z1-沉思\",\"desc\":\"能自主执行“实时搜索、深度分析、自我验证”全流程，以完成复杂研究任务的智能体。\"},\"featureDescription\":\"专为龙虾场景打造的基座模型，从训练层深度优化Agent核心能力，大幅提升工具调用与长链路执行能力。\",\"featureTitle\":\"GLM-5-Turbo\",\"subtitle\":\"新一代大模型全栈技术体系\",\"title\":\"GLM模型\"},\"glm_130b\":{\"desc\":\"中国第一个开源千亿模型\"},\"glm_4_6v\":{\"desc\":\"全球 100B 级效果表现出众的开源视觉推理模型\"},\"glm_5\":{\"desc\":\"GLM-5 达到开源模型 SOTA，比肩 Claude Opus 4.5\"},\"glm_5_t\":{\"desc\":\"专为龙虾场景打造的基座模型\"},\"glm_image\":{\"desc\":\"智谱联合华为开源首个国产芯片训练的多模态 SOTA 模型\"},\"hello_world\":\"你好世界\",\"help_me_write\":\"Help Me Write\",\"introduction_desc\":\"自主创新的算法、领先的中文认知大模型企业\",\"introduction_title\":\"公司简介\",\"issue_description\":\"请描述您想要咨询的问题\",\"join_us_desc\":\"一群正直的、有激情的年轻人，聚在一起，做创新的、对社会有价值的事\",\"join_us_title\":\"加入我们\",\"joinus\":{\"benefits\":{\"annual_leave\":{\"description\":\"平衡工作，享受生活，让我们在忙碌中也能拥抱悠闲时光，为身心充电\",\"title\":\"丰厚的年假\"},\"flexible_hours\":{\"description\":\"自由工作，高效非凡，员工可根据自身情况灵活安排，轻松应对繁忙工作，提升工作幸福感\",\"title\":\"弹性办工时间\"},\"team_building\":{\"description\":\"欢乐时光，凝聚力量，大家在轻松氛围中交流分享，增进感情，携手共进\",\"title\":\"下午茶团建\"},\"title\":\"智谱福利\"},\"hero\":{\"campus_recruitment\":\"校园招聘\",\"social_recruitment\":\"社会招聘\",\"subtitle\":